indicator(
     title = "TITAN ONE",
     shorttitle = "TITAN",
     overlay = true,
     max_labels_count = 500,
     max_lines_count = 500,
     max_boxes_count = 500)

//══════════════════════════════════════════════════════════════
// FOUNDATION
//══════════════════════════════════════════════════════════════

const string TITAN_VERSION = "Alpha 0.1"
const string TITAN_BUILD   = "0001"

//══════════════════════════════════════════════════════════════
// INPUTS
//══════════════════════════════════════════════════════════════

groupGeneral = "General"

showDebug = input.bool(
     false,
     "Debug Mode",
     group = groupGeneral)

showInfo = input.bool(
     true,
     "Show Version",
     group = groupGeneral)

//══════════════════════════════════════════════════════════════
// COLORS
//══════════════════════════════════════════════════════════════

colorBull = color.rgb(0, 200, 120)
colorBear = color.rgb(220, 70, 70)
colorInfo = color.rgb(50, 150, 255)

//══════════════════════════════════════════════════════════════
// INITIALIZATION
//══════════════════════════════════════════════════════════════

if barstate.islast and showInfo
    label.new(
         bar_index,
         high,
         "TITAN ONE\n" +
         TITAN_VERSION +
         "\nBuild " +
         TITAN_BUILD,
         style = label.style_label_down,
         color = colorInfo,
         textcolor = color.white)
//══════════════════════════════════════════════════════════════
// MODULE 02 : DATA ENGINE
//══════════════════════════════════════════════════════════════

//--------------------------------------------------------------
// Candle Metrics
//--------------------------------------------------------------

float candleRange = high - low
float candleBody  = math.abs(close - open)

float upperWick = high - math.max(open, close)
float lowerWick = math.min(open, close) - low

//--------------------------------------------------------------
// Candle Ratios
//--------------------------------------------------------------

float bodyPercent =
     candleRange > 0
     ? candleBody / candleRange
     : 0.0

//--------------------------------------------------------------
// Candle Classification
//--------------------------------------------------------------

bool isBull = close > open
bool isBear = close < open

bool isDoji =
     candleBody <= candleRange * 0.10

//--------------------------------------------------------------
// Volatility
//--------------------------------------------------------------

float atr14 = ta.atr(14)

float avgRange =
     ta.sma(candleRange, 20)
//══════════════════════════════════════════════════════════════
// DATA ENGINE API
//══════════════════════════════════════════════════════════════

//--------------------------------------------------------------
// Basic Candle Functions
//--------------------------------------------------------------

Titan_GetRange() =>
    high - low

Titan_GetBody() =>
    math.abs(close - open)

Titan_GetUpperWick() =>
    high - math.max(open, close)

Titan_GetLowerWick() =>
    math.min(open, close) - low

//--------------------------------------------------------------
// Candle Classification
//--------------------------------------------------------------

Titan_IsBullish() =>
    close > open

Titan_IsBearish() =>
    close < open

Titan_IsDoji() =>
    Titan_GetBody() <= Titan_GetRange() * 0.10

//--------------------------------------------------------------
// Ratios
//--------------------------------------------------------------

Titan_GetBodyPercent() =>
    Titan_GetRange() > 0 ? Titan_GetBody() / Titan_GetRange() : 0.0

//--------------------------------------------------------------
// Volatility
//--------------------------------------------------------------

Titan_GetATR(int length) =>
    ta.atr(length)

Titan_GetAverageRange(int length) =>
    ta.sma(Titan_GetRange(), length)
//--------------------------------------------------------------
// Debug View
//--------------------------------------------------------------

if showDebug and barstate.islast
    label.new(
         bar_index,
         low,
         "DATA ENGINE\n" +
         "Range : " + str.tostring(Titan_GetRange()) +
         "\nBody : " + str.tostring(Titan_GetBody()) +
         "\nATR : " + str.tostring(Titan_GetATR(14)),
         style = label.style_label_up,
         color = color.gray,
         textcolor = color.white)
